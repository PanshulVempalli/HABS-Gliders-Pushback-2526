{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\nfrom vex import *\n\n# Creating objects to be used later\nbrain = Brain()\ncontroller = Controller()\n\n# Default to linear (raw) joystick input\nuseNonlinearJoystick = False\ntogglePressedLast = False  # Tracks previous state of ButtonA\n\n# Left-side motor initialisation\nleftMotors = MotorGroup(\n    Motor(Ports.PORT1, GearSetting.RATIO_18_1, False),\n    Motor(Ports.PORT3, GearSetting.RATIO_18_1, False),\n    Motor(Ports.PORT5, GearSetting.RATIO_18_1, False)\n)\n\n# Right-side motors initialisation (reversed)\nrightMotors = MotorGroup(\n    Motor(Ports.PORT2, GearSetting.RATIO_18_1, True),\n    Motor(Ports.PORT4, GearSetting.RATIO_18_1, True),\n    Motor(Ports.PORT6, GearSetting.RATIO_18_1, True)\n)\n\n# Function to optionally apply non-linear response\ndef adjustInput(value, nonlinear=False):\n    if nonlinear:\n        scaled = value / 100\n        adjusted = scaled ** 3\n        return adjusted * 100\n    return value\n\n# Arcade-style driving with adjustable joystick curve\ndef arcadeDrive(forwardInput, turnInput):\n    leftSpeed = forwardInput + turnInput\n    rightSpeed = forwardInput - turnInput\n\n    # Clamp values to [-100, 100]\n    leftSpeed = max(-100, min(100, leftSpeed))\n    rightSpeed = max(-100, min(100, rightSpeed))\n\n    leftMotors.spin(FORWARD, leftSpeed, PERCENT)\n    rightMotors.spin(FORWARD, rightSpeed, PERCENT)\n\ndef driveTrainLoop():\n    global useNonlinearJoystick, togglePressedLast\n\n    # Continuous drivetrain control loop\n    while True:\n        # Check if ButtonA is being pressed (used to toggle input mode)\n        togglePressed = controller.buttonA.pressing()\n\n        # Toggle mode only once per button press\n        if togglePressed and not togglePressedLast:\n            useNonlinearJoystick = not useNonlinearJoystick  # Switch between modes\n            brain.screen.clear_screen()\n            mode = \"Non-linear\" if useNonlinearJoystick else \"Linear\" #assigns mode variable the string for whatever mode is currently in use\n            brain.screen.print(f\"Mode: {mode}\")  # Display current mode on Brain screen for easier testing\n\n        togglePressedLast = togglePressed  # Store current state for next loop\n\n        # Get raw input values from joystick axes\n        rawForwardInput = controller.axis2.position()  # Forward/backward control\n        rawTurnInput = controller.axis4.position()     # Left/right turning control\n\n        # Apply joystick processing (linear or non-linear) based on current mode\n        forwardInput = adjustInput(rawForwardInput, useNonlinearJoystick)\n        turnInput = adjustInput(rawTurnInput, useNonlinearJoystick)\n\n        arcadeDrive(forwardInput, turnInput)\n\n        # Reduce battery usage by waiting 10 milliseconds per iteration\n        wait(10, MSEC)\n\ndef main():\n    # Program entry point\n\n    # Start drivetrain control loop\n    driveTrainLoop()\n\n","textLanguage":"python","robotConfig":[],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.0.7","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false}